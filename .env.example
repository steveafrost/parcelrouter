# iCloud Mail IMAP Configuration
# Generate an app-specific password at: https://appleid.apple.com/
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_USER=your.email@icloud.com
IMAP_PASS=your-app-specific-password

# Optional Parcel API sync
# Leave blank to use Parcel Tracker as a local-only package dashboard.
# Add a key from https://parcel.app/account/api to sync detected packages to Parcel.
PARCEL_API_KEY=

# Optional webhooks
# Send package/review events to Home Assistant, n8n, Zapier, ntfy bridges, or your own endpoint.
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_MS=5000

# Polling Configuration (optional)
# How often to check for new emails (in seconds, default: 3600 = 1 hour)
POLL_INTERVAL=3600

# Server Configuration (optional)
PORT=3000
NODE_ENV=production
